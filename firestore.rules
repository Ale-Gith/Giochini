rules_version = '2';

// ════════════════════════════════════════════════════════════════════
//  Firestore Security Rules — Lo Sborriamo MMXXVI
// ════════════════════════════════════════════════════════════════════
//  Da incollare in Firebase Console:
//    Firestore Database → Rules → Publish
//
//  Strategia: Anonymous Auth + soft security.
//  Solo utenti autenticati (anonymous OK) possono leggere/scrivere.
//  La verifica "owner-only" è applicata lato client (UI nasconde l'upload).
//  Per blindare server-side servirebbe Firebase Auth Email Link, futuro upgrade.
// ════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // Eventi del gioco (premi/penalità assegnati ai pirati).
    // Tutti i loggati leggono. Tutti i loggati scrivono.
    match /events/{eventId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }

    // Manifesto (catalog premi/penalità caricato dall'owner via excel).
    // Tutti i loggati leggono. Tutti i loggati scrivono (soft: owner via UI).
    match /catalog/{itemId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null;
    }

    // Default deny per tutto il resto.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
